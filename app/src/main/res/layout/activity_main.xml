<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="20dp">

    <!-- 按钮1：普通打开 -->
    <Button
        android:id="@+id/btn_open_normal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="1. 普通打开第二页"
        android:layout_marginBottom="20dp"/>

    <!-- 按钮2：带参数打开并获取结果 (新API) -->
    <Button
        android:id="@+id/btn_open_result"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="2. 打开并获取返回结果 (新API)"
        android:layout_marginBottom="20dp"/>

    <!-- 按钮3：演示取消情况 -->
    <Button
        android:id="@+id/btn_open_cancel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="3. 打开并测试取消返回"/>

    <!-- 用来显示返回结果的文本 -->
    <TextView
        android:id="@+id/tv_result_show"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="这里将显示返回结果..."
        android:textSize="16sp"
        android:gravity="center"
        android:layout_marginTop="30dp"/>

</LinearLayout>